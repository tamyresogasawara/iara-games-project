  {
    "id": "uit-header",
    "type": "ui_template",
    "group": "grp-header",
    "name": "Banner Iara Games",
    "order": 1,
    "width": "12",
    "height": "5",
    "format": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');\n  md-card, .nr-dashboard-template, md-content, .nr-widget-header, .nr-dashboard-background { background: #0f0f23 !important; }\n  .iara-banner { font-family: Inter, sans-serif; text-align: center; padding: 28px 24px; background: #0f0f23; border-radius: 14px; border: 3px solid #8b5cf6; }\n  .iara-title { color: #8b5cf6; margin: 0; font-size: 28px; letter-spacing: 4px; font-weight: 800; text-transform: uppercase; }\n  .iara-sub { color: #cbd5e1; margin: 8px 0 4px; font-size: 13px; font-weight: 400; }\n  .iara-phase { color: #6366f1; margin: 0; font-size: 11px; letter-spacing: 2px; font-weight: 600; text-transform: uppercase; }\n  .iara-badges { display: flex; justify-content: center; gap: 10px; margin-top: 16px; flex-wrap: wrap; }\n  .badge { font-size: 11px; padding: 5px 12px; border-radius: 20px; font-weight: 600; }\n  .badge-green { color: #10b981; background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.3); }\n  .badge-purple { color: #a78bfa; background: rgba(139,92,246,0.12); border: 1px solid rgba(139,92,246,0.3); }\n  .badge-pink { color: #ec4899; background: rgba(236,72,153,0.12); border: 1px solid rgba(236,72,153,0.3); }\n  .iara-games-list { display: flex; justify-content: center; gap: 14px; margin-top: 14px; flex-wrap: wrap; }\n  .game-tag { color: #64748b; font-size: 10px; padding: 3px 8px; border-radius: 4px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); }\n</style>\n<div class=\"iara-banner\">\n  <h1 class=\"iara-title\">🎮 Iara Games</h1>\n  <p class=\"iara-sub\">Plataforma de Jogos Indies Brasileiros</p>\n  <p class=\"iara-phase\">Painel Interativo · Fase 5 &amp; 6 · URLs Dinâmicas · Consumo de APIs</p>\n  <div class=\"iara-badges\">\n    <span class=\"badge badge-green\">✅ FreeToGame API</span>\n    <span class=\"badge badge-green\">✅ JSONPlaceholder API</span>\n    <span class=\"badge badge-purple\">⚡ HTTP Request Node</span>\n    <span class=\"badge badge-pink\">🔗 Template + Change</span>\n  </div>\n  <div class=\"iara-games-list\">\n    <span class=\"game-tag\">Chroma Squad</span>\n    <span class=\"game-tag\">Dandara</span>\n    <span class=\"game-tag\">Blazing Chrome</span>\n    <span class=\"game-tag\">Horizon Chase Turbo</span>\n    <span class=\"game-tag\">Dodgeball Academia</span>\n    <span class=\"game-tag\">Kaze and the Wild Masks</span>\n  </div>\n</div>",
    "storeOutMessages": false,
    "fwdInMessages": false,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 300,
    "y": 80,
    "wires": [[]]
  },

  {
    "id": "uit-stats",
    "type": "ui_template",
    "group": "grp-stats",
    "name": "Stats Plataforma",
    "order": 1,
    "width": "12",
    "height": "4",
    "format": "<style>\n  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; padding: 8px; font-family: Inter, sans-serif; }\n  .stat-card { background: #0f0f23; border: 3px solid #8b5cf6; border-radius: 10px; padding: 18px; text-align: center; transition: border-color 0.2s; }\n  .stat-card:hover { border-color: #a78bfa; }\n  .stat-icon { font-size: 26px; }\n  .stat-value { color: #8b5cf6; font-size: 26px; font-weight: 800; margin: 6px 0 2px; }\n  .stat-label { color: #64748b; font-size: 11px; font-weight: 500; letter-spacing: 0.5px; }\n  @media (max-width: 640px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }\n</style>\n<div class=\"stats-grid\">\n  <div class=\"stat-card\"><div class=\"stat-icon\">🎮</div><div class=\"stat-value\">48</div><div class=\"stat-label\">Jogos Cadastrados</div></div>\n  <div class=\"stat-card\"><div class=\"stat-icon\">👥</div><div class=\"stat-value\">1.247</div><div class=\"stat-label\">Usuários Ativos</div></div>\n  <div class=\"stat-card\"><div class=\"stat-icon\">🏢</div><div class=\"stat-value\">12</div><div class=\"stat-label\">Estúdios Parceiros</div></div>\n  <div class=\"stat-card\"><div class=\"stat-icon\">⭐</div><div class=\"stat-value\">3.891</div><div class=\"stat-label\">Avaliações</div></div>\n</div>",
    "storeOutMessages": false,
    "fwdInMessages": false,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 300,
    "y": 160,
    "wires": [[]]
  },

