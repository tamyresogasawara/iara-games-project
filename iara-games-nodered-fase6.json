  {
    "id": "fn-user",
    "type": "function",
    "name": "Formatar Usuário",
    "func": "try {\n    if (msg.statusCode && msg.statusCode !== 200) {\n        msg.payload = { error: 'Usuário não encontrado. Use IDs de 1 a 10.' };\n        return msg;\n    }\n    var user = msg.payload;\n    if (!user || !user.id) {\n        msg.payload = { error: 'Usuário não encontrado. Digite um ID de 1 a 10.' };\n        return msg;\n    }\n    msg.payload = {\n        id: user.id,\n        name: user.name,\n        username: user.username,\n        email: user.email,\n        phone: user.phone,\n        website: user.website,\n        address: {\n            street: user.address.street,\n            city: user.address.city,\n            zipcode: user.address.zipcode\n        },\n        company: {\n            name: user.company.name,\n            catchPhrase: user.company.catchPhrase\n        }\n    };\n    return msg;\n} catch(e) {\n    msg.payload = { error: 'Erro ao processar resposta: ' + e.message };\n    return msg;\n}",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 970,
    "y": 520,
    "wires": [["uit-user"]]
  },

  {
    "id": "uit-user",
    "type": "ui_template",
    "group": "grp-users",
    "name": "Resultado Usuário",
    "order": 3,
    "width": "12",
    "height": "8",
    "format": "<style>\n  .user-wrap { font-family: Inter, sans-serif; padding: 8px; }\n  .user-hint { color: #64748b; padding: 24px; text-align: center; font-size: 13px; border: 1px dashed rgba(99,102,241,0.2); border-radius: 8px; }\n  .user-card { background: #0f0f23; border: 3px solid #8b5cf6; border-radius: 12px; padding: 24px; }\n  .user-avatar { width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, #6366f1, #8b5cf6); display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 14px; }\n  .user-name { color: #a78bfa; font-size: 20px; font-weight: 700; margin: 0 0 4px; }\n  .user-username { color: #6366f1; font-size: 13px; margin: 0 0 16px; }\n  .user-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }\n  .user-field { background: #0f0f23; border: 3px solid #8b5cf6; border-radius: 6px; padding: 10px; }\n  .field-label { color: #64748b; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 4px; }\n  .field-value { color: #cbd5e1; font-size: 13px; margin: 0; word-break: break-all; }\n  .user-company { margin-top: 14px; background: rgba(99,102,241,0.08); border: 1px solid rgba(99,102,241,0.2); border-radius: 8px; padding: 12px; }\n  .company-name { color: #8b5cf6; font-size: 14px; font-weight: 600; margin: 0 0 4px; }\n  .company-phrase { color: #64748b; font-size: 11px; font-style: italic; margin: 0; }\n  .user-error { color: #f87171; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); border-radius: 8px; padding: 16px; font-size: 13px; }\n  @media (max-width: 500px) { .user-fields { grid-template-columns: 1fr; } }\n</style>\n<div class=\"user-wrap\">\n  <div ng-if=\"!msg.payload\" class=\"user-hint\">\n    Digite um ID de usuário (1 a 10) e pressione Enter para consultar o perfil.<br>\n    <small style=\"color:#475569;\">Simulação da tabela <strong style='color:#6366f1'>usuarios</strong> do RDS Iara Games</small>\n  </div>\n  <div ng-if=\"msg.payload\">\n    <div ng-if=\"msg.payload.error\" class=\"user-error\">⚠️ {{msg.payload.error}}</div>\n    <div ng-if=\"!msg.payload.error\" class=\"user-card\">\n      <div class=\"user-avatar\">👤</div>\n      <h2 class=\"user-name\">{{msg.payload.name}}</h2>\n      <p class=\"user-username\">@{{msg.payload.username}} · ID #{{msg.payload.id}}</p>\n      <div class=\"user-fields\">\n        <div class=\"user-field\"><p class=\"field-label\">📧 Email</p><p class=\"field-value\">{{msg.payload.email}}</p></div>\n        <div class=\"user-field\"><p class=\"field-label\">📱 Telefone</p><p class=\"field-value\">{{msg.payload.phone}}</p></div>\n        <div class=\"user-field\"><p class=\"field-label\">🌐 Website</p><p class=\"field-value\">{{msg.payload.website}}</p></div>\n        <div class=\"user-field\"><p class=\"field-label\">📍 Cidade</p><p class=\"field-value\">{{msg.payload.address.city}}</p></div>\n      </div>\n      <div class=\"user-company\">\n        <p class=\"company-name\">🏢 {{msg.payload.company.name}}</p>\n        <p class=\"company-phrase\">\"{{msg.payload.company.catchPhrase}}\"</p>\n      </div>\n    </div>\n  </div>\n</div>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 1180,
    "y": 520,
    "wires": [[]]
  },

