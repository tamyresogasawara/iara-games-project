  {
    "id": "http-games",
    "type": "http request",
    "name": "GET FreeToGame API",
    "method": "GET",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "{{{url}}}",
    "tls": "",
    "persist": false,
    "proxy": "",
    "authType": "",
    "x": 750,
    "y": 340,
    "wires": [["fn-games"]]
  },

  {
    "id": "fn-games",
    "type": "function",
    "name": "Formatar Jogos",
    "func": "try {\n    if (msg.statusCode && msg.statusCode !== 200) {\n        msg.payload = { error: 'A API retornou erro (status ' + msg.statusCode + '). Verifique o gênero informado.' };\n        return msg;\n    }\n    var games = msg.payload;\n    if (!Array.isArray(games)) {\n        msg.payload = { error: 'Gênero não encontrado. Tente: action, rpg, shooter, mmorpg, strategy, moba, racing, sports, sandbox, survival, card, battle-royale, anime, fantasy' };\n        return msg;\n    }\n    var shown = games.slice(0, 12);\n    msg.payload = {\n        games: shown.map(function(g) {\n            return {\n                title: g.title,\n                thumbnail: g.thumbnail,\n                genre: g.genre,\n                platform: g.platform,\n                developer: g.developer,\n                release_date: g.release_date,\n                game_url: g.game_url\n            };\n        }),\n        total: games.length,\n        shown: shown.length\n    };\n    return msg;\n} catch(e) {\n    msg.payload = { error: 'Erro ao processar resposta da API: ' + e.message };\n    return msg;\n}",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 960,
    "y": 340,
    "wires": [["uit-games"]]
  },

  {
    "id": "uit-games",
    "type": "ui_template",
    "group": "grp-games",
    "name": "Resultado Jogos",
    "order": 3,
    "width": "12",
    "height": "12",
    "format": "<style>\n  .games-wrap { font-family: Inter, sans-serif; padding: 8px; }\n  .games-hint { color: #64748b; padding: 24px; text-align: center; font-size: 13px; border: 1px dashed rgba(99,102,241,0.2); border-radius: 8px; }\n  .games-count { color: #6366f1; font-size: 12px; margin: 0 0 12px; font-weight: 600; }\n  .games-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }\n  .game-card { background: #0f0f23; border: 3px solid #8b5cf6; border-radius: 10px; overflow: hidden; transition: border-color 0.2s, transform 0.2s; }\n  .game-card:hover { border-color: #a78bfa; transform: translateY(-2px); }\n  .game-thumb { width: 100%; height: 110px; object-fit: cover; display: block; }\n  .game-info { padding: 10px; }\n  .game-title { color: #a78bfa; font-size: 13px; font-weight: 700; margin: 0 0 5px; line-height: 1.3; }\n  .game-genre { color: #cbd5e1; font-size: 11px; margin: 2px 0; }\n  .game-platform { color: #6366f1; font-size: 10px; margin: 2px 0; }\n  .game-dev { color: #64748b; font-size: 10px; margin: 4px 0 0; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 4px; }\n  .games-error { color: #f87171; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); border-radius: 8px; padding: 16px; font-size: 13px; }\n</style>\n<div class=\"games-wrap\">\n  <div ng-if=\"!msg.payload\" class=\"games-hint\">\n    Digite um gênero acima e pressione Enter para buscar jogos na FreeToGame API.<br>\n    <small style=\"color:#475569;\">Exemplos: action · rpg · shooter · mmorpg · strategy · moba · racing · sports</small>\n  </div>\n  <div ng-if=\"msg.payload\">\n    <div ng-if=\"msg.payload.error\" class=\"games-error\">⚠️ {{msg.payload.error}}</div>\n    <div ng-if=\"!msg.payload.error\">\n      <p class=\"games-count\">🎮 {{msg.payload.total}} jogos encontrados · exibindo {{msg.payload.shown}}</p>\n      <div class=\"games-grid\">\n        <div class=\"game-card\" ng-repeat=\"game in msg.payload.games\">\n          <img class=\"game-thumb\" ng-src=\"{{game.thumbnail}}\" alt=\"{{game.title}}\">\n          <div class=\"game-info\">\n            <p class=\"game-title\">{{game.title}}</p>\n            <p class=\"game-genre\">🎯 {{game.genre}}</p>\n            <p class=\"game-platform\">🖥️ {{game.platform}}</p>\n            <p class=\"game-dev\">{{game.developer}}</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 1180,
    "y": 340,
    "wires": [[]]
  },

