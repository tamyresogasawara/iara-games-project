  {
    "id": "http-forum",
    "type": "http request",
    "name": "GET JSONPlaceholder Posts",
    "method": "GET",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "{{{url}}}",
    "tls": "",
    "persist": false,
