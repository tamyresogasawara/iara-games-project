  },

  {
    "id": "fn-forum",
    "type": "function",
    "name": "Formatar Tópicos Fórum",
    "func": "try {\n    if (msg.statusCode && msg.statusCode !== 200) {\n        msg.payload = { error: 'Erro na API (status ' + msg.statusCode + '). Tente novamente.' };\n        return msg;\n    }\n    var posts = msg.payload;\n    if (!Array.isArray(posts) || posts.length === 0) {\n        msg.payload = { error: 'Nenhum tópico encontrado para este usuário. Use IDs de 1 a 10.' };\n        return msg;\n    }\n    msg.payload = {\n        posts: posts.map(function(p) {\n            return {\n                id: p.id,\n                title: p.title,\n                body: p.body\n            };\n        }),\n        total: posts.length\n    };\n    return msg;\n} catch(e) {\n    msg.payload = { error: 'Erro ao processar resposta: ' + e.message };\n    return msg;\n}",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 980,
    "y": 700,
    "wires": [["uit-forum"]]
  },

  {
    "id": "uit-forum",
    "type": "ui_template",
    "group": "grp-forum",
    "name": "Resultado Fórum",
    "order": 3,
    "width": "12",
    "height": "12",
    "format": "<style>\n  .forum-wrap { font-family: Inter, sans-serif; padding: 8px; }\n  .forum-hint { color: #64748b; padding: 24px; text-align: center; font-size: 13px; border: 1px dashed rgba(99,102,241,0.2); border-radius: 8px; }\n  .forum-count { color: #ec4899; font-size: 12px; margin: 0 0 12px; font-weight: 600; }\n  .forum-list { display: flex; flex-direction: column; gap: 10px; }\n  .forum-post { background: #0f0f23; border-left: 3px solid #8b5cf6; border-radius: 0 8px 8px 0; padding: 14px; transition: border-left-color 0.2s; }\n  .forum-post:hover { border-left-color: #a78bfa; }\n  .post-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }\n  .post-title { color: #a78bfa; font-size: 14px; font-weight: 600; margin: 0; text-transform: capitalize; flex: 1; line-height: 1.3; }\n  .post-id { color: #475569; font-size: 10px; font-weight: 600; background: rgba(99,102,241,0.1); padding: 2px 7px; border-radius: 4px; margin-left: 8px; white-space: nowrap; }\n  .post-body { color: #94a3b8; font-size: 12px; line-height: 1.6; margin: 0; }\n  .forum-error { color: #f87171; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); border-radius: 8px; padding: 16px; font-size: 13px; }\n</style>\n<div class=\"forum-wrap\">\n  <div ng-if=\"!msg.payload\" class=\"forum-hint\">\n    Digite um ID de usuário (1 a 10) e pressione Enter para listar os tópicos do fórum.<br>\n    <small style=\"color:#475569;\">Simulação do módulo de fórum da plataforma Iara Games</small>\n  </div>\n  <div ng-if=\"msg.payload\">\n    <div ng-if=\"msg.payload.error\" class=\"forum-error\">⚠️ {{msg.payload.error}}</div>\n    <div ng-if=\"!msg.payload.error\">\n      <p class=\"forum-count\">💬 {{msg.payload.total}} tópicos encontrados para este usuário</p>\n      <div class=\"forum-list\">\n        <div class=\"forum-post\" ng-repeat=\"post in msg.payload.posts\">\n          <div class=\"post-header\">\n            <p class=\"post-title\">{{post.title}}</p>\n            <span class=\"post-id\">#{{post.id}}</span>\n          </div>\n          <p class=\"post-body\">{{post.body}}</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 1200,
    "y": 700,
    "wires": [[]]
  },

  {
    "id": "catch-http",
    "type": "catch",
    "name": "Capturar Erros HTTP",
    "scope": ["http-games", "http-user", "http-forum"],
    "uncaught": false,
